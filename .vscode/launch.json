{
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "HelloSwiftApp (.app Hata Ayıkla)",
      "program": "${workspaceFolder}/HelloSwiftApp.app/Contents/MacOS/HelloSwiftApp",
      "args": [],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "macOS Package Build"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:HelloSwiftApp}",
      "name": "Debug HelloSwiftApp",
      "target": "HelloSwiftApp",
      "configuration": "debug",
      "preLaunchTask": "swift: Build Debug HelloSwiftApp"
    },
    {
      "type": "swift",
      "request": "launch",
      "args": [],
      "cwd": "${workspaceFolder:HelloSwiftApp}",
      "name": "Release HelloSwiftApp",
      "target": "HelloSwiftApp",
      "configuration": "release",
      "preLaunchTask": "swift: Build Release HelloSwiftApp"
    }
  ]
}
